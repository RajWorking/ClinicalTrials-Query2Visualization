# Copy to .env and fill in.
# The planner uses OpenRouter (https://openrouter.ai) — an OpenAI-compatible
# proxy that routes to GPT-4o-mini by default.

OPENROUTER_API_KEY=sk-or-v1-...

# Optional overrides:
# OPENROUTER_MODEL=openai/gpt-4o-mini      # default model
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1  # default endpoint
# OPENROUTER_SITE_URL=http://localhost:8000
# OPENROUTER_APP_NAME=Cheiron

# OPENAI_API_KEY is accepted as a fallback if OPENROUTER_API_KEY is unset.
